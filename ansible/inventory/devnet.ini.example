[devnet_bootstrap]
mettacycle-devnet-1 ansible_host=REPLACE_IP

[devnet_val1]
mettacycle-devnet-2 ansible_host=REPLACE_IP

[devnet_val2]
mettacycle-devnet-3 ansible_host=REPLACE_IP

[devnet_val3]
mettacycle-devnet-4 ansible_host=REPLACE_IP

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/asi_chain
