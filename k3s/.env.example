# Bootstrap node ID — derived from TLS key via keccak256(pubkey_x || pubkey_y)[12:]
# Run 'make gen' to populate all values below
BOOTSTRAP_NODE_ID=

# Network
NETWORK_ID=testnet

# Validator keypairs — generated by 'make gen' via gen_validator_keys.py
# Do NOT commit .env (it contains private keys)
VALIDATOR1_PUBLIC_KEY=
VALIDATOR1_PRIVATE_KEY=

VALIDATOR2_PUBLIC_KEY=
VALIDATOR2_PRIVATE_KEY=

VALIDATOR3_PUBLIC_KEY=
VALIDATOR3_PRIVATE_KEY=
